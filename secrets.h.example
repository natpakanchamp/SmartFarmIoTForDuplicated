#ifndef SECRETS_H
#define SECRETS_H

// ===================== WiFi Credentials =====================
#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// ===================== MQTT Broker =====================
#define MQTT_BROKER   "your-mqtt-broker.example.com"
#define MQTT_PORT     1883
#define MQTT_USER     "your-mqtt-username"
#define MQTT_PASS     "your-mqtt-password"

// ===================== ThingsBoard / Device API =====================
#define TB_HOST_ADDR    "your-thingsboard-host.example.com"
#define TB_DEVICE_TOKEN "your-device-token"

// ===================== OTA =====================
#define OTA_FIRMWARE_URL "https://your-domain.com/firmware.bin"

// ===================== ESP-NOW MAC Addresses =====================
// Node A MAC (sender) - used by Node B to filter allowed senders
#define NODE_A_MAC {0x00, 0x00, 0x00, 0x00, 0x00, 0x00}

// Node B MAC (receiver) - used by Node A to send data
#define NODE_B_MAC_ADDR {0x00, 0x00, 0x00, 0x00, 0x00, 0x00}

#endif // SECRETS_H
